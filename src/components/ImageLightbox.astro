---
// Lightbox – click to enlarge images in #article.
// Supports pinch-to-zoom (mobile) and mouse-wheel zoom (desktop).
---

<div
  id="lightbox"
  class="fixed inset-0 z-50 flex items-center justify-center bg-black/85 backdrop-blur-sm"
  role="dialog"
  aria-modal="true"
  aria-label="Image preview"
  aria-hidden="true"
>
  <!-- Controls bar (top-right) -->
  <div class="absolute top-4 right-4 flex items-center gap-2">
    <!-- Zoom level badge / reset button – hidden when zoom = 1 -->
    <button
      id="lightbox-zoom-reset"
      hidden
      class="cursor-pointer rounded-full bg-white/10 px-2.5 py-1.5 text-xs font-medium text-white/80 transition-colors hover:bg-white/25 hover:text-white focus-visible:outline-2 focus-visible:outline-white"
      aria-label="Reset zoom"
    ></button>
    <!-- Close button -->
    <button
      id="lightbox-close"
      class="cursor-pointer rounded-full bg-white/10 p-2 text-white/80 transition-colors hover:bg-white/25 hover:text-white focus-visible:outline-2 focus-visible:outline-white"
      aria-label="Close image preview"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="22"
        height="22"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M18 6 6 18"></path>
        <path d="m6 6 12 12"></path>
      </svg>
    </button>
  </div>

  <!--
    #lightbox-inner handles the pop-in animation.
    The <img> inside receives the JS zoom/pan transform separately,
    so the two transforms don't conflict.
  -->
  <div
    id="lightbox-inner"
    class="flex max-h-full max-w-full flex-col items-center gap-3 p-14"
  >
    <img
      id="lightbox-img"
      src=""
      alt=""
      class="max-h-[85vh] max-w-full rounded object-contain shadow-2xl select-none"
    />
    <figcaption
      id="lightbox-caption"
      class="text-center text-sm text-white/65"
    ></figcaption>
  </div>
</div>

<style>
  #lightbox {
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }
  #lightbox.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  #lightbox-inner {
    pointer-events: none;
    transform: scale(0.9);
    transition: transform 0.25s cubic-bezier(0.34, 1.15, 0.64, 1);
  }
  #lightbox.is-open #lightbox-inner {
    transform: scale(1);
  }

  #lightbox-img {
    /* touch-action set dynamically so it never blocks page scroll when closed */
    pointer-events: auto;
    will-change: transform;
  }

  :global(#article img) {
    cursor: zoom-in;
  }
</style>

<script>
  const MIN_ZOOM = 1;
  const MAX_ZOOM = 5;

  let zoom = 1;
  let panX = 0;
  let panY = 0;
  let isDragging = false;
  let wasDragging = false;
  let dragStartX = 0;
  let dragStartY = 0;
  let panXOnDragStart = 0;
  let panYOnDragStart = 0;
  let isPinching = false;
  let lastPinchDist = 0;
  let singleTouchId = -1;
  let touchStartX = 0;
  let touchStartY = 0;
  let panXOnTouchStart = 0;
  let panYOnTouchStart = 0;

  // Aborted when the lightbox closes – removes all gesture/keyboard listeners at once.
  let gestureController: AbortController | null = null;

  function getTouchDist(touches: TouchList) {
    return Math.hypot(
      touches[0].clientX - touches[1].clientX,
      touches[0].clientY - touches[1].clientY
    );
  }

  function applyTransform(img: HTMLImageElement) {
    // translate3d promotes the element to its own compositor layer → no layout/paint on move
    img.style.transform = `translate3d(${panX}px, ${panY}px, 0) scale(${zoom})`;
    img.style.cursor = zoom > 1 ? (isDragging ? "grabbing" : "grab") : "default";
  }

  function setZoom(
    newZoom: number,
    img: HTMLImageElement,
    zoomResetBtn: HTMLButtonElement,
    originX = 0,
    originY = 0
  ) {
    const prevZoom = zoom;
    zoom = Math.min(MAX_ZOOM, Math.max(MIN_ZOOM, newZoom));

    if (zoom <= MIN_ZOOM) {
      zoom = MIN_ZOOM;
      panX = 0;
      panY = 0;
    } else if (prevZoom !== zoom) {
      const ratio = zoom / prevZoom;
      panX = originX * (1 - ratio) + panX * ratio;
      panY = originY * (1 - ratio) + panY * ratio;
    }

    applyTransform(img);
    zoomResetBtn.hidden = zoom <= MIN_ZOOM;
    zoomResetBtn.textContent = `${zoom.toFixed(1)}×`;
  }

  function initLightbox() {
    zoom = 1; panX = 0; panY = 0;
    isDragging = false; wasDragging = false;

    const lightbox    = document.getElementById("lightbox")!;
    const img         = document.getElementById("lightbox-img") as HTMLImageElement;
    const caption     = document.getElementById("lightbox-caption")!;
    const closeBtn    = document.getElementById("lightbox-close")!;
    const zoomResetBtn = document.getElementById("lightbox-zoom-reset") as HTMLButtonElement;

    function resetZoom() {
      zoom = 1; panX = 0; panY = 0;
      img.style.transform = "";
      img.style.cursor = "default";
      zoomResetBtn.hidden = true;
    }

    function open(src: string, alt: string) {
      gestureController?.abort();
      gestureController = new AbortController();
      const { signal } = gestureController;

      img.src = src;
      img.alt = alt;
      caption.textContent = alt;
      caption.hidden = !alt;
      resetZoom();

      // Only block native touch scroll/zoom while the lightbox is actually open
      img.style.touchAction = "none";

      lightbox.setAttribute("aria-hidden", "false");
      lightbox.classList.add("is-open");
      document.body.style.overflow = "hidden";
      closeBtn.focus();

      // ── Wheel zoom ──────────────────────────────────────────────
      lightbox.addEventListener(
        "wheel",
        e => {
          e.preventDefault();
          const rect = lightbox.getBoundingClientRect();
          const cx = e.clientX - (rect.left + rect.width / 2);
          const cy = e.clientY - (rect.top + rect.height / 2);
          setZoom(zoom * (e.deltaY < 0 ? 1.15 : 1 / 1.15), img, zoomResetBtn, cx, cy);
        },
        { passive: false, signal }
      );

      // ── Mouse drag ──────────────────────────────────────────────
      img.addEventListener(
        "mousedown",
        e => {
          if (zoom <= 1) return;
          isDragging = true;
          wasDragging = false;
          dragStartX = e.clientX;
          dragStartY = e.clientY;
          panXOnDragStart = panX;
          panYOnDragStart = panY;
          img.style.cursor = "grabbing";
          e.preventDefault();
        },
        { signal }
      );

      document.addEventListener(
        "mousemove",
        e => {
          if (!isDragging) return;
          const dx = e.clientX - dragStartX;
          const dy = e.clientY - dragStartY;
          if (Math.hypot(dx, dy) > 3) wasDragging = true;
          panX = panXOnDragStart + dx;
          panY = panYOnDragStart + dy;
          applyTransform(img);
        },
        { signal }
      );

      document.addEventListener(
        "mouseup",
        () => {
          if (!isDragging) return;
          isDragging = false;
          applyTransform(img);
        },
        { signal }
      );

      // ── Touch pinch + pan ────────────────────────────────────────
      img.addEventListener(
        "touchstart",
        e => {
          if (e.touches.length === 2) {
            isPinching = true;
            lastPinchDist = getTouchDist(e.touches);
          } else if (e.touches.length === 1 && zoom > 1) {
            singleTouchId = e.touches[0].identifier;
            touchStartX = e.touches[0].clientX;
            touchStartY = e.touches[0].clientY;
            panXOnTouchStart = panX;
            panYOnTouchStart = panY;
          }
          e.preventDefault();
        },
        { passive: false, signal }
      );

      img.addEventListener(
        "touchmove",
        e => {
          if (e.touches.length === 2) {
            const dist = getTouchDist(e.touches);
            setZoom(zoom * (dist / lastPinchDist), img, zoomResetBtn);
            lastPinchDist = dist;
          } else if (e.touches.length === 1 && zoom > 1 && !isPinching) {
            const touch = e.touches[0];
            if (touch.identifier === singleTouchId) {
              panX = panXOnTouchStart + (touch.clientX - touchStartX);
              panY = panYOnTouchStart + (touch.clientY - touchStartY);
              applyTransform(img);
            }
          }
          e.preventDefault();
        },
        { passive: false, signal }
      );

      img.addEventListener(
        "touchend",
        e => {
          if (e.touches.length < 2) isPinching = false;
          if (e.touches.length === 0) singleTouchId = -1;
        },
        { signal }
      );

      // ── Keyboard ────────────────────────────────────────────────
      document.addEventListener(
        "keydown",
        e => {
          if (e.key === "Escape") close();
          if (e.key === "0") resetZoom();
        },
        { signal }
      );
    }

    function close() {
      gestureController?.abort();
      gestureController = null;
      img.style.touchAction = "";
      lightbox.setAttribute("aria-hidden", "true");
      lightbox.classList.remove("is-open");
      document.body.style.overflow = "";
      resetZoom();
    }

    // ── Static listeners (always active) ────────────────────────────
    lightbox.addEventListener("click", e => {
      if (wasDragging) { wasDragging = false; return; }
      if (e.target === lightbox) close();
    });

    closeBtn.addEventListener("click", close);

    zoomResetBtn.addEventListener("click", e => {
      e.stopPropagation();
      resetZoom();
    });

    document
      .getElementById("article")
      ?.querySelectorAll("img")
      .forEach(articleImg => {
        articleImg.addEventListener("click", () => open(articleImg.src, articleImg.alt));
      });
  }

  initLightbox();
  document.addEventListener("astro:after-swap", initLightbox);
</script>
